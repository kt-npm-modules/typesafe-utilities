{
	"name": "@ktarmyshov/typesafe-utilities",
	"description": "Type-safe utilities for working in TypeScript. For example, a type-safe property path type, deep partial type, etc.",
	"version": "1.0.1",
	"license": "MIT",
	"author": {
		"name": "Konstantin Tarmyshov",
		"email": "k.tarmyshov@googlemail.com"
	},
	"keywords": [
		"typescript",
		"type-safe",
		"typesafe",
		"property",
		"path",
		"string",
		"property-path",
		"deep partial"
	],
	"homepage": "https://github.com/kt-npm-modules/typesafe-utilities#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kt-npm-modules/typesafe-utilities.git"
	},
	"bugs": {
		"url": "https://github.com/kt-npm-modules/typesafe-utilities/issues"
	},
	"scripts": {
		"build": "rimraf ./dist && tsc --project tsconfig.json && npm run prepack",
		"build:release": "rimraf ./dist && tsc --project tsconfig-release.json && npm run prepack",
		"prepack": "publint",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "tsc --project tsconfig.json --noEmit",
		"check:test": "tsc --project tsconfig-test.json",
		"test": "npm run check:test && vitest run --run",
		"coverage": "npm run check:test && vitest run --coverage",
		"changeset:version": "changeset version && npm install && git add --all",
		"changeset:publish": "changeset publish"
	},
	"files": [
		"dist",
		"CHANGELOG.md",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"devDependencies": {
		"@changesets/cli": "^2.28.1",
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.0.0",
		"@vitest/coverage-v8": "^4.1.7",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.1",
		"globals": "^17.4.0",
		"prettier": "^3.5.3",
		"publint": "^0.3.9",
		"rimraf": "^6.0.1",
		"type-fest": "^5.0.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.26.1",
		"vitest": "^4.0.3"
	},
	"engines": {
		"node": ">=22"
	}
}
